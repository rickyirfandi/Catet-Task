{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/nicegui/main/.github/tauri-v2-schema.json",
  "productName": "Jira TimeTracker",
  "version": "0.0.4",
  "identifier": "com.jtt.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "trayIcon": {
      "id": "main-tray",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "title": ""
    },
    "windows": [
      {
        "label": "main",
        "title": "Jira TimeTracker",
        "width": 340,
        "height": 520,
        "resizable": false,
        "decorations": false,
        "visible": true,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "positioner": {}
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: Ricky Irfandi (D Q9BG7QYPT)",
      "providerShortName": "D Q9BG7QYPT",
      "minimumSystemVersion": "10.15",
      "infoPlist": "Info.plist"
    }
  }
}
